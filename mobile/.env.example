# Supabase (Authentication → API in dashboard)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Optional: FastAPI backend (dashboard/activities still use this if JWT is accepted)
# EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:8000/api/v1

# Optional: verbose [IronFit] console.log + one-time /health probe (default off)
# EXPO_PUBLIC_DEBUG=1
