PORT=8000
SECRET_KEY=change-me-in-production
DATABASE_URL=sqlite:///./ironfit.db
GOOGLE_CLIENT_ID=

# Supabase (optional): same JWT Secret as Dashboard → Project Settings → API → JWT Secret
# Lets the API accept the mobile app’s Supabase access_token (Bearer).
SUPABASE_JWT_SECRET=
# For ES256 tokens: https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWKS_URL=
